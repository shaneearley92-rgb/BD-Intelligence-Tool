# ===========================================
# BD Intelligence Tool - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values.
# These same values go into GitHub Secrets for Actions.

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key

# --- Anthropic (Claude API) ---
ANTHROPIC_API_KEY=sk-ant-...your-key

# --- Exa.ai (web research) ---
EXA_API_KEY=exa-...your-key

# --- YouTube Data API ---
YOUTUBE_API_KEY=AIza...your-key

# --- Apollo.io (optional, for future contact enrichment) ---
# APOLLO_API_KEY=your-apollo-key

# --- GitHub (for dashboard to trigger workflows) ---
# Fine-grained PAT with Actions:write permission on this repo
# GITHUB_PAT=ghp_...your-token
# GITHUB_OWNER=shaneearley92-rgb
# GITHUB_REPO=BD-Intelligence-Tool
